# Amazon Product Advertising API (PA-API v5)
#
# Never commit real keys. Create `.env` locally.
#
# Access keys from your Amazon Associates / PA-API console.
AMAZON_PA_ACCESS_KEY_ID=
AMAZON_PA_SECRET_ACCESS_KEY=

# Your Associates tracking ID (usually ends with -20 for US).
AMAZON_PA_PARTNER_TAG=
AMAZON_PA_PARTNER_TYPE=Associates

# Defaults are for Amazon US (amazon.com).
AMAZON_PA_HOST=webservices.amazon.com
AMAZON_PA_REGION=us-east-1
AMAZON_PA_MARKETPLACE=www.amazon.com

# Optional
AMAZON_PA_TIMEOUT_S=30
