# Sample config for Amazon Product Advertising API (PA-API v5)
# Copy this to `.env` and then replace the placeholder values.
# Do not commit your real `.env`.

AMAZON_PA_ACCESS_KEY_ID=YOUR_AMAZON_PA_ACCESS_KEY_ID
AMAZON_PA_SECRET_ACCESS_KEY=YOUR_AMAZON_PA_SECRET_ACCESS_KEY
AMAZON_PA_PARTNER_TAG=YOUR_PARTNER_TAG
AMAZON_PA_PARTNER_TYPE=Associates
AMAZON_PA_HOST=webservices.amazon.com
AMAZON_PA_REGION=us-east-1
AMAZON_PA_MARKETPLACE=www.amazon.com
AMAZON_PA_TIMEOUT_S=30
